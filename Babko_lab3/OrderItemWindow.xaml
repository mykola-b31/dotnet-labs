<Window x:Class="Babko_lab3.OrderItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Позиція замовлення" Height="400" Width="400">
    <Grid>
        <StackPanel Margin="10" Orientation="Vertical">
            <StackPanel.Resources>
                <Style TargetType="{x:Type Label}">
                    <Setter Property="Margin" Value="5,5,5,0"/>
                </Style>
                <Style TargetType="{x:Type TextBox}">
                    <Setter Property="Margin" Value="5,0,5,5"/>
                </Style>
                <Style TargetType="{x:Type ComboBox}">
                    <Setter Property="Margin" Value="5,0,5,5"/>
                </Style>
                <Style TargetType="{x:Type Button}">
                    <Setter Property="Margin" Value="5,10,10,5"/>
                </Style>
            </StackPanel.Resources>

            <Label Content="Товар" Name="Label1" />
            <ComboBox MinWidth="300" HorizontalAlignment="Left" Name="ComboGoods" DisplayMemberPath="Name" SelectionChanged="ComboGoods_SelectionChanged" />

            <Label Content="Кількість" Name="Label2" />
            <TextBox MinWidth="300" HorizontalAlignment="Left" Name="InputQuantity"/>

            <Label Content="Ціна (за позицію)" Name="Label3" />
            <TextBox MinWidth="300" HorizontalAlignment="Left" Name="InputPrice"/>

            <Button Content="Зберегти" Name="SaveButton" Click="ButtonSave_Click" />
            <Button Content="Скасувати" Name="CancelButton" Click="ButtonCancel_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>